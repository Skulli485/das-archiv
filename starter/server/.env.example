# Kopiere diese Datei zu .env (optional). Ohne Redis laeuft der Server spaeter
# automatisch mit In-Memory-Map — dieselbe Grenze, nur ein anderer Speicher.
PORT=3000
CACHE_TTL=60
# Wegwerf-Redis auf 6380 (NIE die echte 6379). Start per Docker:
#   docker run -d --rm -p 6380:6379 --name archiv_redis redis:alpine
REDIS_URL=redis://localhost:6380
